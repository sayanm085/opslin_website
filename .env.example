# All variables here are public (NEXT_PUBLIC_*) — none are secrets, they're
# just the URLs this site links out to. Copy this file to .env.local and
# adjust for your environment.

# Canonical URL of this site itself (used for metadata, robots.txt, sitemap.xml).
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Where "Sign in" / "Get started" / "Start Free Beta" CTAs point.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Where the admin-console link points (only shown if you link to it).
NEXT_PUBLIC_ADMIN_URL=http://localhost:3003

# Where the "Docs" nav link points.
NEXT_PUBLIC_DOCS_URL=http://localhost:3002

# Optional: if set, page events (cta_click, demo_play, pricing_click, etc.)
# are POSTed here as JSON. Leave unset to disable analytics entirely.
# NEXT_PUBLIC_ANALYTICS_URL=
